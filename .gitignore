# .gitignore for Personal_info project

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environment directories
env/
venv/
.venv/
ENV/

# Distribution / packaging
build/
dist/
*.egg-info/

# IDEs and editors
.vscode/
.idea/

# OS files
.DS_Store
Thumbs.db

# Local test input / temp files (generated during testing)
test_inputs.txt
_input.tmp

# Misc
*.tmp
*.log
